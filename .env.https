# API Configuration - HTTPS Mode
# Sử dụng file này khi backend chạy HTTPS trên port 7172
# Đổi tên file này thành .env để sử dụng

VITE_API_URL=https://localhost:7172/api

# SignalR Hub URL
VITE_SIGNALR_URL=https://localhost:7172/quizhub

# Backend base URL (for images/uploads)
VITE_BACKEND_URL=https://localhost:7172

# Google OAuth Client ID (optional)
VITE_GOOGLE_CLIENT_ID=

# App Configuration
VITE_APP_NAME=QuizHub
VITE_APP_VERSION=1.0.0
