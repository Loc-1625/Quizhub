# API Configuration
# HTTP: http://localhost:5099/api
# HTTPS: https://localhost:7172/api
VITE_API_URL=http://localhost:5099/api

# SignalR Hub URL
# HTTP: http://localhost:5099/hubs/quiz
# HTTPS: https://localhost:7172/hubs/quiz
VITE_SIGNALR_URL=http://localhost:5099/hubs/quiz

# Backend base URL (for images/uploads)
VITE_BACKEND_URL=http://localhost:5099

# Google OAuth Client ID (optional)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# reCAPTCHA (v2/v3)
VITE_RECAPTCHA_ENABLED=false
VITE_RECAPTCHA_VERSION=v2
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Idle session timeout (minutes)
VITE_IDLE_TIMEOUT_MINUTES=15

# Maintenance mode
VITE_IS_MAINTENANCE=false

# App Configuration
VITE_APP_NAME=QuizHub
VITE_APP_VERSION=1.0.0
