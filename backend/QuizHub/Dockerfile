FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY ["QuizHub/QuizHub.csproj", "QuizHub/"]
RUN dotnet restore "QuizHub/QuizHub.csproj"

COPY . .
WORKDIR /src/QuizHub
RUN dotnet publish "QuizHub.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "QuizHub.dll"]
