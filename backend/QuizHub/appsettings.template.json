{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_MACHINE_NAME\\YOUR_SQL_INSTANCE;Database=QuizHubDB;Integrated Security=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_BASE64_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "QuizHubAPI",
    "Audience": "QuizHubClient",
    "ExpirationMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:8080",
      "http://localhost:3000"
    ]
  },
  "Frontend": {
    "BaseUrl": "http://localhost:5173"
  },
  "Recaptcha": {
    "Enabled": false,
    "Version": "v3",
    "SiteKey": "YOUR_RECAPTCHA_SITE_KEY",
    "SecretKey": "YOUR_RECAPTCHA_SECRET_KEY",
    "MinimumScore": 0.5,
    "VerifyUrl": "https://www.google.com/recaptcha/api/siteverify"
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    }
  },
  "GeminiAI": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-2.5-flash",
    "MaxTokens": 200000,
    "Temperature": 1
  },
  "EmailSettings": {
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "YOUR_SMTP_USERNAME",
      "Password": "YOUR_SMTP_PASSWORD",
      "FromEmail": "noreply@quizhub.com",
      "FromName": "QuizHub",
      "EnableSsl": true
    }
  }
}
