# =============================================
# QuizHub Docker environment variables
# =============================================

# SQL Server SA password for docker-compose (must satisfy SQL Server complexity)
# - at least 8 chars
# - uppercase, lowercase, number, special char
MSSQL_SA_PASSWORD=Your_strong_Password123!

# Optional: override backend connection string in Docker.
# If omitted, docker-compose.yml default value will be used.
# ConnectionStrings__DefaultConnection=Server=sqlserver,1433;Database=QuizHubDB;User Id=sa;Password=Your_strong_Password123!;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=true
